{
  "policy_id": "raw-span-policy",
  "description": "Rollover raw spans every 24h, delete after 30 days",
  "default_state": "current_write_index",
  "states": [
    {
      "name": "current_write_index",
      "actions": [
        {
          "retry": {
            "count": 3,
            "backoff": "exponential",
            "delay": "1m"
          },
          "rollover": {
            "min_size": "50gb",
            "min_index_age": "24h"
          }
        }
      ],
      "transitions": [
        {
          "state_name": "delete",
          "conditions": {
            "min_index_age": "30d"
          }
        }
      ]
    },
    {
      "name": "delete",
      "actions": [
        {
          "delete": {}
        }
      ],
      "transitions": []
    }
  ],
  "ism_template": {
    "index_patterns": ["otel-v1-apm-span-*"],
    "priority": 100
  }
}